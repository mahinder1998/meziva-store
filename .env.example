# ---- Admin panel (/admin/login, /admin/orders) ----
# Choose your own strong password — this isn't auto-generated.
ADMIN_PASSWORD=ChangeThisToAStrongPassword123!
# Random long string used to sign admin session cookies — any long random
# value works, it just needs to stay secret and not change (changing it logs
# everyone out). Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# ---- Razorpay (Cards / UPI / Netbanking) ----
# Get test keys free at https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Same key id, exposed to the browser (NEXT_PUBLIC_ prefix required by Next.js).
# Must be EXACTLY the same value as RAZORPAY_KEY_ID above.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Shiprocket (order -> shipment sync) ----
# IMPORTANT: use an "API User" (Settings > Additional Settings > API Users
# in the Shiprocket dashboard), NOT your normal dashboard login.
SHIPROCKET_EMAIL=your-api-user-email
SHIPROCKET_PASSWORD=your-api-user-password
SHIPROCKET_PICKUP_LOCATION=Primary

# ---- Order Alerts: Email ----
# Works with ANY SMTP provider. If using Hostinger's own email hosting for
# your domain (e.g. support@meziva.in), find these details in hPanel > Emails
# > Connect Devices/Configure Mail Client. If using Gmail, you must create an
# "App Password" (not your normal Gmail password) at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=support@meziva.in
SMTP_PASSWORD=your-email-account-password
# Where new-order alerts get sent (can be the same as SMTP_USER, or a different inbox)
ADMIN_NOTIFY_EMAIL=support@meziva.in

# ---- Order Alerts: WhatsApp (via CallMeBot — free, personal-use API) ----
# One-time setup (~2 minutes), done from YOUR OWN WhatsApp:
#   1. Save +34 644 91 96 80 to your phone contacts (any name is fine).
#   2. Message that contact: "I allow callmebot to send me messages"
#   3. Within ~2 minutes you'll get a reply containing your APIKEY.
#   4. Paste your own WhatsApp number + that key below.
WHATSAPP_NOTIFY_PHONE=+919999999999
CALLMEBOT_API_KEY=123456
